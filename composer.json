{
    "name": "athwari/laravel-zkteco-adms-server",
    "description": "Laravel package implementing the ZKTeco ADMS protocol for biometric attendance devices.",
    "keywords": [
        "athwari",
        "laravel",
        "zkteco",
        "adms",
        "biometric",
        "attendance",
        "fingerprint",
        "iclock"
    ],
    "license": "MIT",
    "type": "library",
    "homepage": "https://github.com/athwari/laravel-zkteco-adms-server",
    "support": {
        "issues": "https://github.com/athwari/laravel-zkteco-adms-server/issues",
        "source": "https://github.com/athwari/laravel-zkteco-adms-server"
    },
    "authors": [
        {
            "name": "Asem Athwari",
            "email": "asem@athwari.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/database": "^11.0|^12.0",
        "illuminate/http": "^11.0|^12.0",
        "illuminate/routing": "^11.0|^12.0",
        "illuminate/events": "^11.0|^12.0",
        "illuminate/console": "^11.0|^12.0",
        "illuminate/log": "^11.0|^12.0"
    },
    "require-dev": {
        "larastan/larastan": "^2.9|^3.0",
        "laravel/pint": "^1.13",
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan": "^1.10|^2.0",
        "phpunit/phpunit": "^10.0|^11.0",
        "rector/rector": "^1.0|^2.0"
    },
    "autoload": {
        "psr-4": {
            "Athwari\\ZktecoAdms\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Athwari\\ZktecoAdms\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Athwari\\ZktecoAdms\\ZktecoAdmsServiceProvider"
            ],
            "aliases": {
                "ZktecoAdms": "Athwari\\ZktecoAdms\\Facades\\ZktecoAdms"
            }
        },
        "branch-alias": {
            "dev-main": "1.x-dev"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "post-autoload-dump": "@composer run prepare",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "format": "vendor/bin/pint",
        "analyse": "vendor/bin/phpstan analyse",
        "refactor": "vendor/bin/rector"
    },
    "config": {
        "sort-packages": true,
        "preferred-install": "dist",
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}